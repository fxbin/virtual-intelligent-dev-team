{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:skill-hub:virtual-intelligent-dev-team:beta-cohort-plan.schema",
  "title": "Virtual Intelligent Dev Team Beta Cohort Plan",
  "type": "object",
  "required": [
    "schema_version",
    "skill_name",
    "rounds"
  ],
  "properties": {
    "schema_version": {
      "const": "beta-cohort-plan/v1"
    },
    "skill_name": {
      "const": "virtual-intelligent-dev-team"
    },
    "rounds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/round"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "string_array": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "persona_target": {
      "type": "object",
      "required": [
        "persona_id",
        "session_count"
      ],
      "properties": {
        "persona_id": {
          "type": "string"
        },
        "session_count": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "round": {
      "type": "object",
      "required": [
        "round_id",
        "fixture_id",
        "planned_sessions",
        "persona_targets",
        "required_scenario_ids",
        "required_trace_ids"
      ],
      "properties": {
        "round_id": {
          "type": "string"
        },
        "fixture_id": {
          "type": "string"
        },
        "planned_sessions": {
          "type": "integer",
          "minimum": 1
        },
        "persona_targets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/persona_target"
          }
        },
        "required_scenario_ids": {
          "$ref": "#/$defs/string_array"
        },
        "required_trace_ids": {
          "$ref": "#/$defs/string_array"
        }
      },
      "additionalProperties": false
    }
  }
}
