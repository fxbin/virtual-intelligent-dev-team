{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:skill-hub:virtual-intelligent-dev-team:beta-simulation-config.schema",
  "title": "Virtual Intelligent Dev Team Beta Simulation Config",
  "type": "object",
  "required": [
    "schema_version",
    "skill_name",
    "round_id",
    "phase",
    "objective",
    "persona_dir",
    "run_output_dir",
    "feedback_ledger_out",
    "round_report_out",
    "summary_command_template",
    "cohort_fixture_source",
    "trace_catalog_source",
    "scenarios",
    "session_plan"
  ],
  "properties": {
    "schema_version": {
      "const": "beta-simulation-config/v1"
    },
    "skill_name": {
      "const": "virtual-intelligent-dev-team"
    },
    "round_id": {
      "type": "string"
    },
    "phase": {
      "type": "string"
    },
    "objective": {
      "type": "string"
    },
    "persona_dir": {
      "type": "string"
    },
    "run_output_dir": {
      "type": "string"
    },
    "feedback_ledger_out": {
      "type": "string"
    },
    "round_report_out": {
      "type": "string"
    },
    "summary_command_template": {
      "type": "string"
    },
    "cohort_fixture_source": {
      "type": "string"
    },
    "trace_catalog_source": {
      "type": "string"
    },
    "scenarios": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/scenario"
      },
      "minItems": 1
    },
    "session_plan": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/session_plan"
      },
      "minItems": 1
    }
  },
  "$defs": {
    "scenario": {
      "type": "object",
      "required": [
        "scenario_id",
        "title",
        "primary_task",
        "success_definition",
        "risk_focus"
      ],
      "properties": {
        "scenario_id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "primary_task": {
          "type": "string"
        },
        "success_definition": {
          "type": "string"
        },
        "risk_focus": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "session_plan": {
      "type": "object",
      "required": [
        "session_id",
        "persona_id",
        "scenario_id",
        "trace_id"
      ],
      "properties": {
        "session_id": {
          "type": "string"
        },
        "persona_id": {
          "type": "string"
        },
        "scenario_id": {
          "type": "string"
        },
        "trace_id": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
