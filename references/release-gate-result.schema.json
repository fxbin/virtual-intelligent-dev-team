{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:skill-hub:virtual-intelligent-dev-team:release-gate-result.schema",
  "title": "Virtual Intelligent Dev Team Release Gate Result",
  "type": "object",
  "required": [
    "generated_at",
    "skill_name",
    "ok",
    "decision",
    "reason",
    "summary",
    "release_label",
    "follow_up",
    "benchmark_json",
    "benchmark_markdown",
    "offline_drill_report",
    "beta_gate",
    "explanation_card",
    "json_report",
    "markdown_report"
  ],
  "properties": {
    "generated_at": {
      "type": "string"
    },
    "skill_name": {
      "const": "virtual-intelligent-dev-team"
    },
    "ok": {
      "type": "boolean"
    },
    "decision": {
      "enum": [
        "ship",
        "hold"
      ]
    },
    "reason": {
      "type": "string"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "release_label": {
      "type": "string"
    },
    "follow_up": {
      "type": "object"
    },
    "benchmark_json": {
      "type": "string"
    },
    "benchmark_markdown": {
      "type": "string"
    },
    "offline_drill_report": {
      "type": [
        "string",
        "null"
      ]
    },
    "beta_gate": {
      "anyOf": [
        {
          "$ref": "#/$defs/beta_gate"
        },
        {
          "type": "null"
        }
      ]
    },
    "explanation_card": {
      "$ref": "#/$defs/explanation_card"
    },
    "json_report": {
      "type": "string"
    },
    "markdown_report": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "decision": {
            "const": "ship"
          }
        }
      },
      "then": {
        "properties": {
          "ok": {
            "const": true
          },
          "follow_up": {
            "$ref": "#/$defs/ship_follow_up"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "decision": {
            "const": "hold"
          }
        }
      },
      "then": {
        "properties": {
          "ok": {
            "const": false
          },
          "follow_up": {
            "$ref": "#/$defs/hold_follow_up"
          }
        }
      }
    }
  ],
  "additionalProperties": false,
  "$defs": {
    "string_array": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "tests_passed",
        "validator_passed",
        "evals_passed",
        "offline_drill_enabled",
        "offline_drill_passed",
        "overall_passed",
        "beta_gate_enabled",
        "beta_gate_passed",
        "beta_gate_decision",
        "beta_gate_round_id"
      ],
      "properties": {
        "tests_passed": {
          "type": "boolean"
        },
        "validator_passed": {
          "type": "boolean"
        },
        "evals_passed": {
          "type": "boolean"
        },
        "offline_drill_enabled": {
          "type": "boolean"
        },
        "offline_drill_passed": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "overall_passed": {
          "type": "boolean"
        },
        "beta_gate_enabled": {
          "type": "boolean"
        },
        "beta_gate_passed": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "beta_gate_decision": {
          "type": [
            "string",
            "null"
          ]
        },
        "beta_gate_round_id": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "beta_gate": {
      "type": "object",
      "required": [
        "enabled",
        "source",
        "generated_at",
        "ok",
        "decision",
        "round_id",
        "reason",
        "report_path",
        "json_report",
        "markdown_report",
        "release_governance_recommended"
      ],
      "properties": {
        "enabled": {
          "const": true
        },
        "source": {
          "type": "string"
        },
        "generated_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "ok": {
          "type": "boolean"
        },
        "decision": {
          "enum": [
            "advance",
            "hold",
            "escalate"
          ]
        },
        "round_id": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "report_path": {
          "type": "string"
        },
        "json_report": {
          "type": "string"
        },
        "markdown_report": {
          "type": "string"
        },
        "release_governance_recommended": {
          "type": "boolean"
        },
        "remediation_brief_json": {
          "type": "string"
        },
        "remediation_brief_markdown": {
          "type": "string"
        },
        "remediation_brief": {
          "type": "object"
        },
        "resume_artifacts": {
          "$ref": "#/$defs/string_array"
        },
        "blockers": {
          "$ref": "#/$defs/string_array"
        },
        "blocker_breakdown": {
          "$ref": "#/$defs/blocker_breakdown"
        }
      },
      "additionalProperties": false
    },
    "explanation_card": {
      "type": "object",
      "required": [
        "workflow_bundle",
        "workflow_bundle_source",
        "workflow_source_explanation",
        "route_evidence",
        "next_action",
        "current_owner",
        "progress_anchor",
        "resume_artifacts"
      ],
      "properties": {
        "workflow_bundle": {
          "type": "string"
        },
        "workflow_bundle_source": {
          "type": "string"
        },
        "workflow_source_explanation": {
          "type": "string"
        },
        "route_evidence": {
          "type": "string"
        },
        "next_action": {
          "type": "string"
        },
        "current_owner": {
          "type": "string"
        },
        "progress_anchor": {
          "type": "string"
        },
        "resume_artifacts": {
          "$ref": "#/$defs/string_array"
        }
      },
      "additionalProperties": false
    },
    "ship_follow_up": {
      "type": "object",
      "required": [
        "loop_state",
        "next_action",
        "release_label",
        "closure_json",
        "closure_markdown",
        "baseline_registration",
        "distilled_pattern_sync",
        "post_release_bootstrap"
      ],
      "properties": {
        "loop_state": {
          "const": "closed"
        },
        "next_action": {
          "const": "archive-and-promote"
        },
        "release_label": {
          "type": "string"
        },
        "closure_json": {
          "type": "string"
        },
        "closure_markdown": {
          "type": "string"
        },
        "baseline_registration": {
          "type": "object"
        },
        "distilled_pattern_sync": {
          "type": "object"
        },
        "post_release_bootstrap": {
          "type": "object",
          "required": [
            "root",
            "resume_anchor",
            "signal_report",
            "artifacts",
            "actions",
            "recommended_command"
          ],
          "properties": {
            "root": {
              "type": "string"
            },
            "resume_anchor": {
              "type": "string"
            },
            "signal_report": {
              "type": "string"
            },
            "artifacts": {
              "$ref": "#/$defs/string_array"
            },
            "actions": {
              "type": "array",
              "items": {
                "type": "object"
              }
            },
            "recommended_command": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "hold_auto_iteration": {
      "type": "object",
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string"
        },
        "result": {},
        "error": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "hold_bootstrap": {
      "type": "object",
      "required": [
        "workspace",
        "candidate_repo",
        "plan_json",
        "open_loops",
        "iteration_context_chain",
        "baseline_registration",
        "distilled_pattern_sync",
        "recommended_command"
      ],
      "properties": {
        "workspace": {
          "type": "string"
        },
        "candidate_repo": {
          "type": "string"
        },
        "plan_json": {
          "type": "string"
        },
        "open_loops": {
          "type": "string"
        },
        "iteration_context_chain": {
          "type": "string"
        },
        "baseline_registration": {
          "type": "object"
        },
        "distilled_pattern_sync": {
          "type": "object"
        },
        "recommended_command": {
          "type": "string"
        },
        "auto_iteration": {
          "$ref": "#/$defs/hold_auto_iteration"
        }
      },
      "additionalProperties": false
    },
    "hold_follow_up": {
      "type": "object",
      "required": [
        "loop_state",
        "next_action",
        "blockers",
        "brief_json",
        "brief_markdown",
        "iteration_workspace"
      ],
      "properties": {
        "loop_state": {
          "const": "reopened"
        },
        "next_action": {
          "const": "bounded-iteration"
        },
        "blockers": {
          "$ref": "#/$defs/string_array"
        },
        "brief_json": {
          "type": "string"
        },
        "brief_markdown": {
          "type": "string"
        },
        "iteration_workspace": {
          "type": "string"
        },
        "bootstrap": {
          "$ref": "#/$defs/hold_bootstrap"
        }
      },
      "additionalProperties": false
    },
    "breakdown_item": {
      "type": "object",
      "required": [
        "label",
        "session_count",
        "blocker_issue_count",
        "critical_issue_count",
        "high_severity_issue_count",
        "session_ids",
        "top_feedback_themes"
      ],
      "properties": {
        "label": {
          "type": "string"
        },
        "session_count": {
          "type": "integer"
        },
        "blocker_issue_count": {
          "type": "integer"
        },
        "critical_issue_count": {
          "type": "integer"
        },
        "high_severity_issue_count": {
          "type": "integer"
        },
        "session_ids": {
          "$ref": "#/$defs/string_array"
        },
        "top_feedback_themes": {
          "$ref": "#/$defs/string_array"
        }
      },
      "additionalProperties": false
    },
    "blocker_breakdown": {
      "type": "object",
      "required": [
        "by_persona",
        "by_scenario"
      ],
      "properties": {
        "by_persona": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/breakdown_item"
          }
        },
        "by_scenario": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/breakdown_item"
          }
        }
      },
      "additionalProperties": false
    }
  }
}
