{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:skill-hub:virtual-intelligent-dev-team:beta-simulation-run.schema",
  "title": "Virtual Intelligent Dev Team Beta Simulation Run",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "skill_name",
    "round_id",
    "phase",
    "objective",
    "config_path",
    "cohort_fixture_source",
    "trace_catalog_source",
    "personas",
    "scenarios",
    "sessions",
    "summary",
    "json_report",
    "markdown_report"
  ],
  "properties": {
    "schema_version": {
      "const": "beta-simulation-run/v1"
    },
    "generated_at": {
      "type": "string"
    },
    "skill_name": {
      "const": "virtual-intelligent-dev-team"
    },
    "round_id": {
      "type": "string"
    },
    "phase": {
      "type": "string"
    },
    "objective": {
      "type": "string"
    },
    "config_path": {
      "type": "string"
    },
    "cohort_fixture_source": {
      "type": "string"
    },
    "trace_catalog_source": {
      "type": "string"
    },
    "personas": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/profile_summary"
      }
    },
    "scenarios": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/scenario"
      }
    },
    "sessions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/session"
      }
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "json_report": {
      "type": "string"
    },
    "markdown_report": {
      "type": "string"
    }
  },
  "$defs": {
    "string_array": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "profile_summary": {
      "type": "object",
      "required": [
        "profile_id",
        "display_name",
        "archetype"
      ],
      "properties": {
        "profile_id": {
          "type": "string"
        },
        "display_name": {
          "type": "string"
        },
        "archetype": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "scenario": {
      "type": "object",
      "required": [
        "scenario_id",
        "title",
        "primary_task",
        "success_definition",
        "risk_focus"
      ],
      "properties": {
        "scenario_id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "primary_task": {
          "type": "string"
        },
        "success_definition": {
          "type": "string"
        },
        "risk_focus": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "event": {
      "type": "object",
      "required": [
        "step_index",
        "event_type",
        "actor_id",
        "scenario_id",
        "action",
        "outcome",
        "severity",
        "observation"
      ],
      "properties": {
        "step_index": {
          "type": "integer"
        },
        "event_type": {
          "enum": [
            "entry",
            "action",
            "hesitation",
            "error",
            "workaround",
            "success",
            "feedback"
          ]
        },
        "actor_id": {
          "type": "string"
        },
        "scenario_id": {
          "type": "string"
        },
        "action": {
          "type": "string"
        },
        "outcome": {
          "enum": [
            "neutral",
            "success",
            "warning",
            "failure"
          ]
        },
        "severity": {
          "enum": [
            "info",
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "observation": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "session": {
      "type": "object",
      "required": [
        "session_id",
        "persona_id",
        "persona_name",
        "scenario_id",
        "scenario_title",
        "trace_id",
        "trace_label",
        "status",
        "task_completed",
        "blocker_detected",
        "critical_issue_detected",
        "high_severity_issue_detected",
        "top_feedback_themes",
        "feedback_summary",
        "events"
      ],
      "properties": {
        "session_id": {
          "type": "string"
        },
        "persona_id": {
          "type": "string"
        },
        "persona_name": {
          "type": "string"
        },
        "scenario_id": {
          "type": "string"
        },
        "scenario_title": {
          "type": "string"
        },
        "trace_id": {
          "type": "string"
        },
        "trace_label": {
          "type": "string"
        },
        "status": {
          "const": "completed"
        },
        "task_completed": {
          "type": "boolean"
        },
        "blocker_detected": {
          "type": "boolean"
        },
        "critical_issue_detected": {
          "type": "boolean"
        },
        "high_severity_issue_detected": {
          "type": "boolean"
        },
        "top_feedback_themes": {
          "$ref": "#/$defs/string_array"
        },
        "feedback_summary": {
          "type": "string"
        },
        "events": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/event"
          },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": [
        "planned_sessions",
        "completed_sessions",
        "task_success_count",
        "blocker_issue_count",
        "critical_issue_count",
        "high_severity_issue_count",
        "top_feedback_themes"
      ],
      "properties": {
        "planned_sessions": {
          "type": "integer"
        },
        "completed_sessions": {
          "type": "integer"
        },
        "task_success_count": {
          "type": "integer"
        },
        "blocker_issue_count": {
          "type": "integer"
        },
        "critical_issue_count": {
          "type": "integer"
        },
        "high_severity_issue_count": {
          "type": "integer"
        },
        "top_feedback_themes": {
          "$ref": "#/$defs/string_array"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
