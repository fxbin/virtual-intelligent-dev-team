{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:skill-hub:virtual-intelligent-dev-team:response-pack-sidecar.schema",
  "title": "Virtual Intelligent Dev Team Response Pack Sidecar",
  "type": "object",
  "required": [
    "schema_version",
    "language",
    "template",
    "team_dispatch",
    "execution_result",
    "evidence",
    "next_action",
    "resume",
    "git_workflow",
    "governance"
  ],
  "properties": {
    "schema_version": {
      "const": "response-pack-sidecar/v1"
    },
    "language": {
      "enum": [
        "en",
        "zh"
      ]
    },
    "template": {
      "enum": [
        "default",
        "review",
        "planning",
        "release",
        "iteration",
        "beta",
        "product",
        "governance"
      ]
    },
    "team_dispatch": {
      "$ref": "#/$defs/team_dispatch"
    },
    "execution_result": {
      "$ref": "#/$defs/execution_result"
    },
    "evidence": {
      "$ref": "#/$defs/evidence"
    },
    "next_action": {
      "$ref": "#/$defs/next_action"
    },
    "resume": {
      "$ref": "#/$defs/resume"
    },
    "git_workflow": {
      "$ref": "#/$defs/git_workflow"
    },
    "governance": {
      "$ref": "#/$defs/governance"
    },
    "bundle_bootstrap": {
      "$ref": "#/$defs/bundle_bootstrap"
    },
    "beta_program": {
      "$ref": "#/$defs/beta_program"
    },
    "planning_pack": {
      "$ref": "#/$defs/planning_pack"
    },
    "optimization_loop": {
      "$ref": "#/$defs/optimization_loop"
    },
    "auto_run": {
      "$ref": "#/$defs/auto_run"
    },
    "automation_resume": {
      "$ref": "#/$defs/automation_resume"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "string_array": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "team_dispatch": {
      "type": "object",
      "required": [
        "lead_agent",
        "assistant_agents",
        "workflow_bundle",
        "bundle_confidence",
        "workflow_bundle_source",
        "route_reason",
        "workflow_source_explanation"
      ],
      "properties": {
        "lead_agent": {
          "type": "string"
        },
        "assistant_agents": {
          "$ref": "#/$defs/string_array"
        },
        "workflow_bundle": {
          "type": "string"
        },
        "bundle_confidence": {
          "type": "number"
        },
        "workflow_bundle_source": {
          "type": "string"
        },
        "route_reason": {
          "type": "string"
        },
        "workflow_source_explanation": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "execution_result": {
      "type": "object",
      "required": [
        "key_conclusion",
        "key_decision",
        "main_risks"
      ],
      "properties": {
        "key_conclusion": {
          "type": "string"
        },
        "key_decision": {
          "type": "string"
        },
        "main_risks": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "object",
      "required": [
        "route_evidence",
        "workflow_source_explanation",
        "process_skills",
        "assistant_delta_contract"
      ],
      "properties": {
        "route_evidence": {
          "type": "string"
        },
        "workflow_source_explanation": {
          "type": "string"
        },
        "process_skills": {
          "$ref": "#/$defs/string_array"
        },
        "assistant_delta_contract": {
          "type": "object",
          "required": [
            "enabled",
            "summary"
          ],
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "summary": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "next_action": {
      "type": "object",
      "required": [
        "smallest_executable_action",
        "current_owner"
      ],
      "properties": {
        "smallest_executable_action": {
          "type": "string"
        },
        "current_owner": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "resume": {
      "type": "object",
      "required": [
        "progress_anchor",
        "resume_artifacts"
      ],
      "properties": {
        "progress_anchor": {
          "type": "string"
        },
        "resume_artifacts": {
          "$ref": "#/$defs/string_array"
        }
      },
      "additionalProperties": false
    },
    "git_workflow": {
      "type": "object",
      "required": [
        "using_git_worktrees",
        "git_workflow",
        "suggested_branch",
        "suggested_commit",
        "suggested_pr_title"
      ],
      "properties": {
        "using_git_worktrees": {
          "type": "boolean"
        },
        "git_workflow": {
          "type": "boolean"
        },
        "suggested_branch": {
          "type": "string"
        },
        "suggested_commit": {
          "type": "string"
        },
        "suggested_pr_title": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "governance": {
      "type": "object",
      "required": [
        "roundtable_enabled",
        "selected_track",
        "risk_level",
        "dual_sign_required"
      ],
      "properties": {
        "roundtable_enabled": {
          "type": "boolean"
        },
        "selected_track": {
          "type": "string"
        },
        "risk_level": {
          "type": "string"
        },
        "dual_sign_required": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "bundle_bootstrap": {
      "type": "object",
      "required": [
        "required",
        "reference",
        "commands",
        "artifacts",
        "resume_anchor"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "reference": {
          "type": "string"
        },
        "commands": {
          "$ref": "#/$defs/string_array"
        },
        "artifacts": {
          "$ref": "#/$defs/string_array"
        },
        "resume_anchor": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "planning_pack": {
      "type": "object",
      "required": [
        "recommended_anchor",
        "workflow_steps"
      ],
      "properties": {
        "recommended_anchor": {
          "type": "string"
        },
        "workflow_steps": {
          "$ref": "#/$defs/string_array"
        }
      },
      "additionalProperties": false
    },
    "beta_round": {
      "type": "object",
      "required": [
        "round_id",
        "phase",
        "sample_size",
        "participant_mode",
        "archetypes",
        "goal",
        "exit_criteria"
      ],
      "properties": {
        "round_id": {
          "type": "string"
        },
        "phase": {
          "type": "string"
        },
        "sample_size": {
          "type": "integer"
        },
        "participant_mode": {
          "type": "string"
        },
        "archetypes": {
          "$ref": "#/$defs/string_array"
        },
        "goal": {
          "type": "string"
        },
        "exit_criteria": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "beta_program": {
      "type": "object",
      "required": [
        "simulation_allowed",
        "feedback_anchor",
        "cohort_artifact",
        "cohort_plan_template",
        "cohort_plan_schema",
        "cohort_plan_path",
        "ramp_plan_template",
        "ramp_plan_schema",
        "ramp_plan_path",
        "simulation_profile_template",
        "simulation_profile_dir",
        "simulation_persona_library",
        "simulation_cohort_fixtures",
        "simulation_config_template",
        "simulation_config_dir",
        "simulation_scenario_packs",
        "simulation_trace_catalog",
        "simulation_preview_dir",
        "simulation_diff_dir",
        "simulation_run_dir",
        "simulation_init_command_template",
        "simulation_preview_command_template",
        "simulation_diff_command_template",
        "simulation_run_command_template",
        "simulation_summary_command_template",
        "report_template",
        "report_dir",
        "decision_dir",
        "gate_command_template",
        "rounds"
      ],
      "properties": {
        "simulation_allowed": {
          "type": "boolean"
        },
        "feedback_anchor": {
          "type": "string"
        },
        "cohort_artifact": {
          "type": "string"
        },
        "cohort_plan_template": {
          "type": "string"
        },
        "cohort_plan_schema": {
          "type": "string"
        },
        "cohort_plan_path": {
          "type": "string"
        },
        "ramp_plan_template": {
          "type": "string"
        },
        "ramp_plan_schema": {
          "type": "string"
        },
        "ramp_plan_path": {
          "type": "string"
        },
        "simulation_profile_template": {
          "type": "string"
        },
        "simulation_profile_dir": {
          "type": "string"
        },
        "simulation_persona_library": {
          "type": "string"
        },
        "simulation_cohort_fixtures": {
          "type": "string"
        },
        "simulation_config_template": {
          "type": "string"
        },
        "simulation_config_dir": {
          "type": "string"
        },
        "simulation_scenario_packs": {
          "type": "string"
        },
        "simulation_trace_catalog": {
          "type": "string"
        },
        "simulation_preview_dir": {
          "type": "string"
        },
        "simulation_diff_dir": {
          "type": "string"
        },
        "simulation_run_dir": {
          "type": "string"
        },
        "simulation_init_command_template": {
          "type": "string"
        },
        "simulation_preview_command_template": {
          "type": "string"
        },
        "simulation_diff_command_template": {
          "type": "string"
        },
        "simulation_run_command_template": {
          "type": "string"
        },
        "simulation_summary_command_template": {
          "type": "string"
        },
        "report_template": {
          "type": "string"
        },
        "report_dir": {
          "type": "string"
        },
        "decision_dir": {
          "type": "string"
        },
        "gate_command_template": {
          "type": "string"
        },
        "rounds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/beta_round"
          }
        }
      },
      "additionalProperties": false
    },
    "optimization_loop": {
      "type": "object",
      "required": [
        "round_cap_online",
        "round_cap_offline",
        "allowed_decisions",
        "resume_anchor"
      ],
      "properties": {
        "round_cap_online": {
          "type": "integer"
        },
        "round_cap_offline": {
          "type": "integer"
        },
        "allowed_decisions": {
          "$ref": "#/$defs/string_array"
        },
        "resume_anchor": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "auto_run": {
      "type": "object",
      "required": [
        "enabled",
        "trigger",
        "requested_phase",
        "execution_mode",
        "run_style",
        "safety_level",
        "resume_requested",
        "detached_ready",
        "workflow_bundle",
        "workflow_supported",
        "requires_explicit_go",
        "eligible_workflows",
        "setup_command",
        "go_command",
        "resume_anchor",
        "state_root",
        "state_dir",
        "plan_json",
        "plan_markdown",
        "automation_state_schema",
        "safety_guards",
        "eligibility_reason"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "trigger": {
          "type": "string"
        },
        "requested_phase": {
          "enum": [
            "setup",
            "go"
          ]
        },
        "execution_mode": {
          "enum": [
            "auto-setup",
            "auto-go"
          ]
        },
        "run_style": {
          "enum": [
            "foreground",
            "background"
          ]
        },
        "safety_level": {
          "enum": [
            "standard",
            "safe"
          ]
        },
        "resume_requested": {
          "type": "boolean"
        },
        "detached_ready": {
          "type": "boolean"
        },
        "workflow_bundle": {
          "type": "string"
        },
        "workflow_supported": {
          "type": "boolean"
        },
        "requires_explicit_go": {
          "type": "boolean"
        },
        "eligible_workflows": {
          "$ref": "#/$defs/string_array"
        },
        "setup_command": {
          "type": "string"
        },
        "go_command": {
          "type": "string"
        },
        "resume_anchor": {
          "type": "string"
        },
        "state_root": {
          "type": "string"
        },
        "state_dir": {
          "type": "string"
        },
        "plan_json": {
          "type": "string"
        },
        "plan_markdown": {
          "type": "string"
        },
        "automation_state_schema": {
          "type": "string"
        },
        "safety_guards": {
          "$ref": "#/$defs/string_array"
        },
        "eligibility_reason": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "automation_resume": {
      "type": "object",
      "required": [
        "enabled",
        "resume_strategy",
        "state_resume_available",
        "selected_state_path",
        "selection_mode",
        "decision_id",
        "decision_label",
        "decision_reason",
        "recommended_command",
        "resume_anchor",
        "playbooks",
        "blocking_conditions",
        "command_allowed",
        "dry_run_command",
        "execute_command",
        "error"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "resume_strategy": {
          "type": "string"
        },
        "state_resume_available": {
          "type": "boolean"
        },
        "selected_state_path": {
          "type": "string"
        },
        "selection_mode": {
          "type": "string"
        },
        "decision_id": {
          "type": "string"
        },
        "decision_label": {
          "type": "string"
        },
        "decision_reason": {
          "type": "string"
        },
        "recommended_command": {
          "type": "string"
        },
        "resume_anchor": {
          "type": "string"
        },
        "playbooks": {
          "$ref": "#/$defs/string_array"
        },
        "blocking_conditions": {
          "$ref": "#/$defs/string_array"
        },
        "command_allowed": {
          "type": "boolean"
        },
        "dry_run_command": {
          "type": "string"
        },
        "execute_command": {
          "type": "string"
        },
        "error": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
